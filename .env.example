# mcp-router environment configuration (example)
# Copy to .env and adjust as needed. All vars are optional; the offline
# pure-stdlib default path runs without any of these set.

# Random seed for reproducible catalog generation and benchmark runs.
MCPR_SEED=1234

# Embedding vector dimensionality used by the embedder and vector index.
MCPR_EMBED_DIM=512

# Number of bootstrap resamples for confidence-interval estimation.
MCPR_BOOTSTRAP_N=1000

# core_share (gold↔query shared tokens) and keyword-collision ratio (cliff knobs).
MCPR_CORE_SHARE=8
MCPR_KW_COLLISION=0.2

# Anthropic API key. Required only for real LLM mode (--llm claude).
ANTHROPIC_API_KEY=
